# Postiz environment variables — copy this file to .env and fill in values
# DO NOT commit the real .env file to git

# Required
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Optional — only needed if you want Postiz UI to schedule X/Twitter posts
X_API_KEY=
X_API_SECRET=

# Optional — LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
